<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Finance</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    
    <link rel="icon" type="image/png" href="~/icon/finance.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-light">

    <div class="d-flex min-vh-100">

        <div class="sidebar p-3 text-white flex-shrink-0" style="width: 250px; background-color: #1a1d2d;">
            <h4 class="text-center mb-4">
                <a class="nav-link text-decoration-none" asp-controller="Transaction" asp-action="Statistics">
                    <img src="~/icon/finance.png" width="50" class="mb-2" /> Finance
                </a>
            </h4>

            <ul class="nav flex-column">
                @if (User.Identity?.IsAuthenticated != true) {
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-controller="Account" asp-action="Login">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                    </a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-controller="Account" asp-action="Register">
                        <i class="bi bi-person-plus me-2"></i>Đăng ký
                    </a>
                </li>
                } else {
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-controller="Wallet" asp-action="Index">
                        <i class="bi bi-wallet me-2"></i> Ví
                    </a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-controller="Transaction" asp-action="Index">
                        <i class="bi bi-arrow-left-right me-2"></i> Giao dịch
                    </a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-controller="Transaction" asp-action="Statistics">
                        <i class="bi bi-bar-chart me-2"></i> Thống kê
                    </a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-controller="Budget" asp-action="Index">
                        <i class="bi bi-pie-chart me-2"></i> Ngân sách
                    </a>
                </li>
                <li class="nav-item mt-4">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="px-3">
                        <button class="btn btn-outline-danger btn-sm w-100 text-start">
                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                        </button>
                    </form>
                </li>
                }
            </ul>
        </div>

        <div class="flex-grow-1 d-flex flex-column bg-white">

            <div class="content flex-grow-1 p-4">
                <main role="main">
                    @RenderBody()
                </main>
            </div>

            <footer class="py-4 bg-light border-top mt-auto">
                <div class="container text-center">
                    <p class="text-muted mb-0 small">© @DateTime.Now.Year - Quản Lý Tài Chính Cá Nhân - Trường Đại Học Trà Vinh</p>
                </div>
            </footer>

        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>