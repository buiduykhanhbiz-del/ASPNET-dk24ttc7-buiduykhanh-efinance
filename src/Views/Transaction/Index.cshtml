@model IEnumerable<PersonalFinanceManager.Models.Transaction>

    @{
    ViewData["Title"] = "Danh Sách Giao Dịch";
    }

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark mb-1">Danh Sách Giao Dịch</h2>
            <a asp-action="Create" class="btn btn-primary">Thêm Giao Dịch Mới</a>
        </div>

        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card">
                    @*<div class="card-header">
                        <h4>Thống Kê Thu/Chi Theo Tháng</h4>    
                    </div>*@
                    <div class="card-body">
                        <canvas id="monthlyChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table id="transactionTable" class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4 py-3 text-secondary uppercase-sm">Ngày</th>
                                        <th class="py-3 text-secondary uppercase-sm">Loại</th>
                                        <th class="py-3 text-secondary uppercase-sm">Danh Mục</th>
                                        <th class="py-3 text-secondary uppercase-sm">Số Tiền</th>
                                        <th class="py-3 text-secondary uppercase-sm">Ghi chú</th>
                                        <th class="py-3 text-secondary uppercase-sm text-center">Ví</th>
                                        <th class="pe-4 py-3 text-end text-secondary uppercase-sm">Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                    {
                                    <tr>
                                        <td class="ps-4">
                                            <span class="text-dark fw-medium">@item.TransactionDate.ToString("dd/MM/yyyy")</span>
                                        </td>
                                        <td>
                                            @if (item.Type == "Income")
                                {
                                            <span class="badge rounded-pill bg-success-soft text-success">
                                                <i class="bi bi-arrow-down-left me-1"></i> Thu
                                            </span>
                                }
                                else
                                {
                                            <span class="badge rounded-pill bg-danger-soft text-danger">
                                                <i class="bi bi-arrow-up-right me-1"></i> Chi
                                            </span>
                                }
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-xs me-2 bg-primary-soft text-primary rounded-circle d-flex align-items-center justify-content-center">
                                                    <i class="bi bi-tag-fill small"></i>
                                                </div>
                                                @item.Category
                                            </div>
                                        </td>
                                        <td class="fw-bold @(item.Type == "Income" ? "text-success" : "text-danger")">
                                            @(item.Type == "Income" ? "+" : "-")@item.Amount.ToString("#,##0") đ
                                        </td>
                                        <td class="text-muted small">@item.Description</td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark border fw-normal">@item.Wallet.Name</span>
                                        </td>
                                        <td class="pe-4 text-end">
                                            <div class="btn-group shadow-none">
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary border-0 hover-primary" title="Sửa">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <button type="button" class="btn btn-sm btn-outline-secondary border-0 hover-danger" onclick="confirmDelete(@item.Id)" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form id="deleteForm" asp-action="Delete" method="post">
        <input type="hidden" id="deleteId" name="id" />
        @Html.AntiForgeryToken()
    </form>

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
        // Logic xóa giao dịch giữ nguyên
        function confirmDelete(id) {
            if (confirm('Bạn có chắc chắn muốn xóa giao dịch này?')) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }

        // Khởi tạo biểu đồ cột theo tháng
        const ctx = document.getElementById('monthlyChart').getContext('2d');
        const monthlyStats = @Html.Raw(Json.Serialize(ViewBag.MonthlyStats));

        // Nhận diện Dark Mode để đổi màu chữ/lưới
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const textColor = isDark ? '#94a3b8' : '#64748b';
        const gridColor = isDark ? '#334155' : '#f1f5f9';

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: monthlyStats.map(stat => stat.monthName),
                datasets: [
                    {
                        label: 'Thu Nhập',
                        data: monthlyStats.map(stat => stat.income),
                        backgroundColor: '#22c55e', // Xanh Emerald hiện đại
                        borderRadius: 6, // Bo góc cột
                        borderSkipped: false,
                        barPercentage: 0.6, // Độ rộng cột
                        categoryPercentage: 0.5
                    },
                    {
                        label: 'Chi Tiêu',
                        data: monthlyStats.map(stat => stat.expense),
                        backgroundColor: '#ef4444', // Đỏ Rose hiện đại
                        borderRadius: 6,
                        borderSkipped: false,
                        barPercentage: 0.6,
                        categoryPercentage: 0.5
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                        align: 'end',
                        labels: {
                            color: textColor,
                            usePointStyle: true, // Chú thích hình tròn cho sang
                            font: { family: 'Inter, sans-serif', size: 12, weight: '500' }
                        }
                    },
                    tooltip: {
                        padding: 12,
                        backgroundColor: isDark ? '#1e293b' : '#ffffff',
                        titleColor: isDark ? '#f8fafc' : '#1e293b',
                        bodyColor: isDark ? '#94a3b8' : '#475569',
                        borderColor: isDark ? '#334155' : '#e2e8f0',
                        borderWidth: 1,
                        boxPadding: 6,
                        callbacks: {
                            label: (context) => ` ${context.dataset.label}: ${context.parsed.y.toLocaleString('vi-VN')} đ`
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false }, // Ẩn lưới dọc để thoáng mắt
                        ticks: { color: textColor, font: { size: 11 } }
                    },
                    y: {
                        beginAtZero: true,
                        border: { display: false },
                        grid: { color: gridColor },
                        ticks: {
                            color: textColor,
                            font: { size: 11 },
                            callback: (value) => value.toLocaleString('vi-VN') + ' đ'
                        }
                    }
                }
            }
        });
        </script>
    }
