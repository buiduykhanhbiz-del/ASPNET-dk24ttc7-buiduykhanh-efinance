@model PersonalFinanceManager.Models.Transaction

@{
    ViewData["Title"] = "Sửa Giao Dịch";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">

            <div class="card shadow-lg border-0 rounded-4">

                <!-- Header -->
                <div class="card-header bg-primary text-white text-center rounded-top-4 py-3">
                    <h4 class="mb-0 fw-bold">💸 Sửa Giao Dịch</h4>
                </div>

                <!-- Body -->
                <div class="card-body p-4">

                    <form asp-action="Edit" onsubmit="return formatNumberBeforeSubmit(this)">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                        <input type="hidden" asp-for="Id" />

                        <!-- Loại giao dịch -->
                        <div class="mb-3">
                            <label asp-for="Type" class="form-label fw-semibold">Loại Giao Dịch</label>
                            <select asp-for="Type" class="form-select">
                                <option value="">-- Chọn loại --</option>
                                <option value="Income">💰 Thu</option>
                                <option value="Expense">💸 Chi</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger small"></span>
                        </div>

                        <!-- Số tiền -->
                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label fw-semibold">Số Tiền</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">₫</span>
                                <input asp-for="Amount"
                                       class="form-control text-end fw-semibold"
                                       type="text"
                                       value="@Model.Amount.ToString("#,##0")"
                                       onkeyup="formatNumber(this)"
                                       placeholder="0" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>

                        <!-- Danh mục -->
                        <div class="mb-3">
                            <label asp-for="Category" class="form-label fw-semibold">Danh Mục</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">📂</span>
                                <input asp-for="Category" class="form-control" placeholder="Nhập danh mục..." />
                            </div>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                        </div>

                        <!-- Mô tả -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Mô Tả</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Ghi chú thêm..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <!-- Ngày -->
                        <div class="mb-3">
                            <label asp-for="TransactionDate" class="form-label fw-semibold">Ngày</label>
                            <input asp-for="TransactionDate" class="form-control" type="date" />
                            <span asp-validation-for="TransactionDate" class="text-danger small"></span>
                        </div>

                        <!-- Ví -->
                        <div class="mb-4">
                            <label asp-for="WalletId" class="form-label fw-semibold">Ví</label>
                            <select asp-for="WalletId" class="form-select"
                                    asp-items="@(new SelectList(ViewBag.Wallets, "Id", "Name"))">
                                <option value="">-- Chọn ví --</option>
                            </select>
                            <span asp-validation-for="WalletId" class="text-danger small"></span>
                        </div>

                        <!-- Button -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                ← Quay Lại
                            </a>
                            <button type="submit" class="btn btn-primary px-4 fw-semibold">
                                💾 Lưu
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function formatNumber(input) {
            // Remove all non-numeric characters
            let value = input.value.replace(/[^\d]/g, '');
            
            // Format with thousand separators
            value = value.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
            
            // Update input value
            input.value = value;
        }

        function formatNumberBeforeSubmit(form) {
            // Get the amount input
            const amountInput = form.querySelector('input[name="Amount"]');
            
            // Remove all dots before submitting
            amountInput.value = amountInput.value.replace(/\./g, '');
            
            return true;
        }
    </script>
} 